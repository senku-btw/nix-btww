# --- Nix / NixOS Artifacts ---
# Result symlinks generated by nix build / nixos-rebuild
result
result-*

# --- Secrets (Crucial if pushing to GitHub) ---
# Common filenames for unencrypted secrets
*secret*.nix
secrets/
.env
.envrc

# --- Optional: Hardware Configuration ---
# Uncomment the line below if you don't want to track hardware UUIDs 
# or if you use this config across multiple distinct machines.
# hardware-configuration.nix

# --- Backup and Temporary Files ---
*.bak
*~
*.old

# --- IDEs and Editors ---
.vscode/
.idea/
.direnv/
*.swp
